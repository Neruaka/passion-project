# PASSION reverse proxy.
# In production, replace :443 with the Tailscale hostname so Caddy binds to the
# Tailscale interface only (ADR-004). HTTPS via Tailscale cert / internal CA.

:443 {
    # Dashboard (Next.js)
    handle /api/* {
        reverse_proxy backend:8000
    }
    handle /ws/* {
        reverse_proxy backend:8000
    }
    handle /grafana/* {
        reverse_proxy grafana-lgtm:3000
    }
    handle {
        reverse_proxy frontend:3000
    }

    # Security headers (NFR-SEC-005)
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
    }
}
