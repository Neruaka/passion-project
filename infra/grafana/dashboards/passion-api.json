{
  "annotations": {"list": []},
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "title": "API up",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "id": 1,
      "targets": [
        {
          "refId": "A",
          "expr": "passion_api_up",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}
          ],
          "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "red"}, {"value": 1, "color": "green"}]}
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Active requests",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "id": 2,
      "targets": [
        {
          "refId": "A",
          "expr": "sum(http_server_active_requests{service_name=\"passion-backend\"})",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      }
    },
    {
      "type": "timeseries",
      "title": "HTTP request rate (per minute, by status)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 3,
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (http_response_status_code) (rate(http_server_duration_milliseconds_count{service_name=\"passion-backend\"}[1m]))",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "legendFormat": "status={{http_response_status_code}}"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqps", "custom": {"drawStyle": "line", "lineWidth": 2}}
      }
    },
    {
      "type": "timeseries",
      "title": "HTTP p95 duration (ms)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 4,
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, http_route) (rate(http_server_duration_milliseconds_bucket{service_name=\"passion-backend\"}[1m])))",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "legendFormat": "{{http_route}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ms"}}
    },
    {
      "type": "logs",
      "title": "Backend logs (last 100)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 5,
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=\"passion-backend\"}",
          "datasource": {"type": "loki", "uid": "loki"}
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["passion", "api"],
  "templating": {"list": []},
  "time": {"from": "now-15m", "to": "now"},
  "timezone": "",
  "title": "PASSION — API overview",
  "uid": "passion-api",
  "version": 2
}
