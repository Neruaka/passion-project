# ============================================================
# PASSION backend — environment template
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

ENVIRONMENT=development
DEBUG=true

# --- Database ---
DATABASE_URL=postgresql+asyncpg://passion:passion@localhost:5432/passion

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Auth (generate hashes with scripts, never store plaintext) ---
JWT_SECRET=change-me-32-bytes-random
ADMIN_PASSWORD_HASH=bcrypt-hash-here
SYSTEM_PASSWORD_HASH=bcrypt-hash-here
JWT_EXPIRY_DAYS=7

# --- LLM providers ---
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...

# --- Integrations ---
HEVY_API_KEY=...
CRONOMETER_USERNAME=...
CRONOMETER_PASSWORD=...
RESEND_API_KEY=...
NTFY_TOPIC=passion-...
RECIPIENT_EMAIL=you@example.com

# --- Ingestion (Tasker / Health Connect) ---
HEALTH_INGEST_TOKEN=long-random-token

# --- Budget caps ---
DAILY_COST_BUDGET_EUR=1.50
DAILY_CALL_BUDGET=50

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://grafana-lgtm:4318
OTEL_SERVICE_NAME=passion-backend
LOG_LEVEL=INFO
LOG_JSON=true
